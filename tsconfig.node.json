{
  "include": ["vite.config.ts", "scripts/**/*.ts"],
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "types": ["node"],
    "lib": ["ES2022"],
    "noEmit": true,
    "skipLibCheck": true
  }
}
